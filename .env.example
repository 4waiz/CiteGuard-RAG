# CiteGuard-RAG environment variables (all optional)

# Optional LLM judge (disabled by default). The core pipeline never needs this.
# CITEGUARD_LLM_JUDGE_ENABLED=false
# CITEGUARD_LLM_JUDGE_MODEL=
# CITEGUARD_LLM_JUDGE_API_KEY=

# Override default sentence-transformer model
# CITEGUARD_SBERT_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Override default NLI model
# CITEGUARD_NLI_MODEL=cross-encoder/nli-deberta-v3-base

# Force CPU even when CUDA is available
# CITEGUARD_FORCE_CPU=1
